-- 3. 플레이어 즉사 처리
local function killPlayer(playerUid)
    local Players = FindAllOf("PalPlayerController")
    for _, player in pairs(Players) do
        local playerState = player:GetPalPlayerState()
        if playerState ~= nil and playerState:IsValid() then
            if playerState.PlayerUId.A == playerUid.A then
                local pawn = player:GetPawn()
                if pawn ~= nil and pawn:IsValid() then
                    pawn.CharacterParameterComponent.HP.Value = 0
                    log("Killed player: " .. playerState.PlayerNamePrivate:ToString())
                    return playerState.PlayerNamePrivate:ToString()
                end
            end
        end
    end
    return nil
end

-- 4. 팰 소환 처리
local function spawnPalForPlayer(playerUid, palId)
    local palIdFName = FName(palId)
    local success = false
    
    -- ModActor의 블루프린트 내 팰 소환 함수 리플렉션 호출 시도
    pcall(function()
        if ModActor ~= nil and ModActor:IsValid() and ModActor.SummonPal ~= nil then
            ModActor:SummonPal(playerUid, palIdFName)
            success = true
        elseif ModActor ~= nil and ModActor:IsValid() and ModActor.SpawnPal ~= nil then
            ModActor:SpawnPal(playerUid, palIdFName)
            success = true
        elseif ModActor ~= nil and ModActor:IsValid() and ModActor.SpawnMonster ~= nil then
            ModActor:SpawnMonster(playerUid, palIdFName)
            success = true
        end
    end)
    
    if success then
        return true
    end
    
    -- 직접 스폰 시도 (ModActor에 함수가 없을 경우)
    local Players = FindAllOf("PalPlayerController")
    for _, player in pairs(Players) do
        local playerState = player:GetPalPlayerState()
        if playerState ~= nil and playerState:IsValid() then
            if playerState.PlayerUId.A == playerUid.A then
                local pawn = player:GetPawn()
                if pawn ~= nil and pawn:IsValid() then
                    local loc = pawn:K2_GetActorLocation()
                    local rot = pawn:K2_GetActorRotation()
                    
                    pcall(function()
                        if PalUtility ~= nil then
                            -- 30레벨 몬스터로 스폰 시도
                            PalUtility:SpawnMonsterType(World, palIdFName, 1, 30, loc, rot)
                            success = true
                        end
                    end)
                end
            end
        end
    end
    return success
end

-- 5. 후원 보상 비즈니스 로직 처리
local function handleDonationRule(playerUid, amount)
    log(string.format("Processing donation rules for UID.A=%d, Amount=%d", playerUid.A, amount))
    
    -- 플레이어 찾기
    local targetName = "플레이어"
    local Players = FindAllOf("PalPlayerController")
    for _, player in pairs(Players) do
        local playerState = player:GetPalPlayerState()
        if playerState ~= nil and playerState:IsValid() then
            if playerState.PlayerUId.A == playerUid.A then
                targetName = playerState.PlayerNamePrivate:ToString()
                break
            end
        end
    end

    if amount == 1000 then
        -- 소모품 룰렛
        local item, grade = getRandomConsumable()
        log(string.format("Roulette (Consumable) selected: %s (%s) x%d", item.name, grade, item.count))
        
        if giveItemToPlayer(playerUid, item.id, item.count) then
            ModActor:Broadcast(string.format("[후원 보상] [%s]님이 1,000원 소모품 룰렛에서 %s 등급 [%s %d개]를 획득했습니다!", targetName, grade, item.name, item.count))
        else
            log("Consumable roulette failed; reward broadcast was suppressed.")
        end
        
    elseif amount == 10000 then
        -- 팰 소환 룰렛
        local pal, grade = getRandomPal()
        log(string.format("Roulette (Pal) selected: %s (%s)", pal.name, grade))
        
        local spawned = spawnPalForPlayer(playerUid, pal.id)
        if spawned then
            ModActor:Broadcast(string.format("[후원 보상] [%s]님 위치에 10,000원 팰 소환 룰렛에서 %s 등급 [%s]이 소환되었습니다!", targetName, grade, pal.name))
        else
            log("Failed to spawn pal: " .. pal.id)
        end
        
    elseif amount == 100000 then
        -- 10만원 즉사
        local killedName = killPlayer(playerUid)
        if killedName ~= nil then
            ModActor:Broadcast(string.format("[후원 피격] [%s]님이 100,000원 후원 즉사 보상으로 사망 처리되었습니다!", killedName))
        else
            log("Failed to kill player UID.A: " .. playerUid.A)
        end
    else
        log("Unhandled donation amount: " .. amount)
    end
end

local function dumpCombatFunctions(label, object)
    if object == nil or not object:IsValid() then
        log(label .. " is unavailable.")
        return
    end

    local class = object:GetClass()
    class:ForEachFunction(function(func)
        local name = func:GetFName():ToString()
        local lowerName = name:lower()
        if lowerName:find("die", 1, true)
            or lowerName:find("death", 1, true)
            or lowerName:find("kill", 1, true)
            or lowerName:find("damage", 1, true)
            or lowerName:find("health", 1, true)
            or lowerName:find("hp", 1, true) then
            log(label .. " candidate: " .. name)
        end
    end)
end

local donationChatCommandHookOk, donationChatCommandHookErr = pcall(function()
    RegisterHook("/Script/Pal.PalGameStateInGame:BroadcastChatMessage", function(_, ChatMessage)
        local chat = ChatMessage:get()
        local message = chat.Message:ToString()
        local command, value = message:match("^!(%S+)%s*(.*)$")
        local normalizedCommand = command and command:lower()
        if normalizedCommand ~= "donationtest"
            and normalizedCommand ~= "donationdebug"
            and normalizedCommand ~= "chzzkregister"
            and normalizedCommand ~= "chzzkstatus"
            and normalizedCommand ~= "chzzkunregister" then
            return
        end

        local playerUid = translateGuid(chat.SenderPlayerUId)
        local playerState = findPlayerStateByUid(playerUid)
        if playerState == nil then
            log("Donation command rejected: sender could not be resolved.")
            return
        end

        if normalizedCommand == "chzzkregister"
            or normalizedCommand == "chzzkstatus"
            or normalizedCommand == "chzzkunregister" then
            local action = normalizedCommand == "chzzkregister" and "register"
                or (normalizedCommand == "chzzkstatus" and "status" or "unregister")
            local playerName = playerState.PlayerNamePrivate:ToString()
            local requestId, requestErr = queueStreamerRegistrationRequest(action, playerUid, playerName, value)
            if requestId == nil then
                log("CHZZK registration request failed: " .. tostring(requestErr))
                sendSystemToPlayer(playerUid, "[CHZZK] Could not contact the channel listener. Check the server listener window.")
            elseif action == "register" then
                sendSystemToPlayer(playerUid, "[CHZZK] Channel registration requested. Check chat for the connection result.")
            elseif action == "status" then
                sendSystemToPlayer(playerUid, "[CHZZK] Checking channel connection status...")
            else
                sendSystemToPlayer(playerUid, "[CHZZK] Removing channel connection...")
            end
            return
        end

        local playerController = playerState:GetPlayerController()
        if playerController == nil or not playerController.bAdmin then
            log("Donation test rejected: sender is not an administrator.")
            return
        end

        if normalizedCommand == "donationdebug" then
            local pawn = playerController:GetPawn()
            dumpCombatFunctions("Pawn", pawn)
            if pawn ~= nil and pawn:IsValid() then
                dumpCombatFunctions("CharacterParameterComponent", pawn.CharacterParameterComponent)
            end
            log("Combat-function dump complete. Check UE4SS.log for DonationMod candidates.")
            return
        end

        local amount = tonumber(value)
        if amount ~= 1000 and amount ~= 10000 and amount ~= 100000 then
            log("Donation test rejected: supported amounts are 1000, 10000, and 100000.")
            return
        end

        ExecuteInGameThread(function()
            local ok, err = pcall(handleDonationRule, playerUid, amount)
            if not ok then
                log("Donation test failed: " .. tostring(err))
            end
        end)
    end)
end)

if not donationChatCommandHookOk then
    log("Donation chat command hook is unavailable: " .. tostring(donationChatCommandHookErr))
end

local function processDonation(playerId, amount, eventId)
    local playerUid = { A = playerId, B = 0, C = 0, D = 0 }
    if not ensureGameReferences() then
        table.insert(pendingDonations, { playerId = playerId, amount = amount, eventId = eventId })
        log("Donation queued until the server world is ready: " .. eventId)
        return
    end

    local ok, err = pcall(handleDonationRule, playerUid, amount)
    if not ok then
        log("Failed to process donation " .. eventId .. ": " .. tostring(err))
    end
end

local function dispatchDonation(playerId, amount, eventId)
    ExecuteInGameThread(function()
        processDonation(playerId, amount, eventId)
    end)
end

local function flushPendingDonations()
    local queuedDonations = pendingDonations
    pendingDonations = {}

    for _, donation in ipairs(queuedDonations) do
        processDonation(donation.playerId, donation.amount, donation.eventId)
    end
end

local function writePlayerStatus()
    local statusFile = io.open(playerStatusPath, "w")
    if statusFile == nil then
        return
    end

    local players = FindAllOf("PalPlayerController") or {}
    for _, player in pairs(players) do
        local playerState = player:GetPalPlayerState()
        if playerState ~= nil and playerState:IsValid() then
            local name = playerState.PlayerNamePrivate:ToString():gsub("[\t\r\n]", " ")
            statusFile:write(tostring(playerState.PlayerUId.A), "\t", name, "\n")
        end
    end
    statusFile:close()
end

local function pollDonationQueue()
    local queueFile = io.open(donationQueuePath, "r")
    if queueFile == nil then
        return
    end

    if donationQueueOffset == nil then
        -- Ignore donation events from before this Lua mod instance started.
        donationQueueOffset = queueFile:seek("end") or 0
        queueFile:close()
        log("Listening for donation events at: " .. donationQueuePath)
        return
    end

    local queueLength = queueFile:seek("end") or 0
    if donationQueueOffset > queueLength then
        donationQueueOffset = 0
    end
    queueFile:seek("set", donationQueueOffset)

    while true do
        local line = queueFile:read("*l")
        if line == nil then
            break
        end
        donationQueueOffset = queueFile:seek()

        local eventId, playerId, amount = line:match("^([^\t]+)\t(-?%d+)\t(%d+)$")
        playerId = tonumber(playerId)
        amount = tonumber(amount)
        if eventId ~= nil and playerId ~= nil and amount ~= nil then
            dispatchDonation(playerId, amount, eventId)
        else
            log("Ignoring malformed donation queue entry.")
        end
    end

    queueFile:close()
end

local function pollStreamerRegistrationResponses()
    local responseFile = io.open(streamerRegistrationResponsePath, "r")
    if responseFile == nil then
        return
    end

    if streamerRegistrationResponseOffset == nil then
        streamerRegistrationResponseOffset = responseFile:seek("end") or 0
        responseFile:close()
        log("Listening for streamer registration responses at: " .. streamerRegistrationResponsePath)
        return
    end

    local responseLength = responseFile:seek("end") or 0
    if streamerRegistrationResponseOffset > responseLength then
        streamerRegistrationResponseOffset = 0
    end
    responseFile:seek("set", streamerRegistrationResponseOffset)

    while true do
        local line = responseFile:read("*l")
        if line == nil then
            break
        end
        streamerRegistrationResponseOffset = responseFile:seek()

        local requestId, rawPlayerId, status, responseMessage = line:match("^([^\t]+)\t(-?%d+)\t([^\t]+)\t(.*)$")
        local playerId = tonumber(rawPlayerId)
        if requestId ~= nil and playerId ~= nil and status ~= nil then
            local playerUid = { A = playerId, B = 0, C = 0, D = 0 }
            local text = "[CHZZK] " .. responseMessage
            sendSystemToPlayer(playerUid, text)
            log("Streamer registration response " .. status .. " for UID.A=" .. tostring(playerId) .. ": " .. responseMessage)
        else
            log("Ignoring malformed streamer registration response.")
        end
    end

    responseFile:close()
end

LoopAsync(250, function()
    local ok, err = pcall(pollDonationQueue)
    if not ok then
        log("Donation queue read failed: " .. tostring(err))
    end
    local registrationOk, registrationErr = pcall(pollStreamerRegistrationResponses)
    if not registrationOk then
        log("Streamer registration response read failed: " .. tostring(registrationErr))
    end
    playerStatusPollCount = playerStatusPollCount + 1
    if playerStatusPollCount >= 20 then
        playerStatusPollCount = 0
        local statusOk, statusErr = pcall(writePlayerStatus)
        if not statusOk then
            log("Player status write failed: " .. tostring(statusErr))
        end
    end
    if #pendingDonations > 0 then
        ExecuteInGameThread(flushPendingDonations)
    end
    return false
end)

RegisterCustomEvent("Donation_Init", function(Context)
    ModActor = Context:get()
    log("DonationMod initialized!")
    
    if PalUtility == nil or not PalUtility:IsValid() then
        PalUtility = StaticFindObject("/Script/Pal.Default__PalUtility")
    end
    if World == nil or not World:IsValid() then
        World = FindFirstOf("World")
    end

    flushPendingDonations()
end)

local chatHookOk, chatHookErr = pcall(function()
RegisterHook("/Script/Pal.PalPlayerState:EnterChat_Receive", function(Context, Chat)
    if ModActor == nil or ModActor == DirectDonationActor or not ModActor:IsValid() then
        return
    end

    local message = Chat:get().Message:ToString()
    local cmd, rest = message:match("^!(%S+)%s*(.*)$")
    if cmd == nil then
        return
    end

    if PalUtility == nil or not PalUtility:IsValid() then
        PalUtility = StaticFindObject("/Script/Pal.Default__PalUtility")
    end
    if World == nil or not World:IsValid() then
        World = FindFirstOf("World")
    end

    local playerState = Context:get()
    local playerUid = translateGuid(playerState.PlayerUId)
    local playerController = playerState:GetPlayerController()
    if not playerController.bAdmin then
        PalUtility:SendSystemToPlayerChat(World, "권한이 없습니다!", playerUid)
        return
    end

    cmd = cmd:lower()
    if cmd == "공지" then
        ModActor:Broadcast(rest)
    elseif cmd == "api" or cmd == "give" then
        local target, arg = rest:match("^(%S+)%s+(.*)$")
        if target == nil then
            PalUtility:SendSystemToPlayerChat(World, "대상이 올바르지 않습니다!", playerUid)
            return
        elseif target == "all" then
            if cmd == "api" then
                PalUtility:SendSystemToPlayerChat(World, "API는 전체 지급을 지원하지 않습니다!", playerUid)
                return
            end
        elseif target ~= "me" then
            local result = findPlayer(target)
            if not result then
                PalUtility:SendSystemToPlayerChat(World, "플레이어를 찾을 수 없습니다!", playerUid)
                return
            end
            playerUid = translateGuid(result)
        end

        if cmd == "api" then
            local amount = tonumber(arg)
            if not amount then
                return
            end
            handleDonationRule(playerUid, amount)
        elseif cmd == "give" then
            local id, count = arg:match("^(%S+)%s*(.*)$")
            if not id then
                return
            end
            id = FName(id)
            count = tonumber(count)
            if count == nil then
                count = 1
            end

            if target == "all" then
                ModActor:GiveAll(id, count)
            else
                ModActor:GiveItem(playerUid, id, count)
            end
        end
    end
end)
end)

if not chatHookOk then
    log("Chat command hook is unavailable in this Palworld version: " .. tostring(chatHookErr))
end

RegisterConsoleCommandGlobalHandler("DonationDumpBindings", function()
    if type(GenerateLuaTypes) ~= "function" then
        log("GenerateLuaTypes is unavailable in this UE4SS build.")
        return true
    end

    log("Generating Palworld Lua bindings. This may take a moment.")
    local ok, err = pcall(GenerateLuaTypes)
    if ok then
        log("Lua binding dump requested. Check Mods\\shared\\types after it completes.")
    else
        log("Lua binding dump failed: " .. tostring(err))
    end
    return true
end)

local function consumeBindingDumpRequest()
    local request = io.open(bindingDumpRequestPath, "r")
    if request == nil then
        return
    end
    request:close()
    os.remove(bindingDumpRequestPath)

    log("Binding-dump request found; starting type generation.")
    ExecuteInGameThread(function()
        if type(GenerateLuaTypes) ~= "function" then
            log("GenerateLuaTypes is unavailable in this UE4SS build.")
            return
        end

        local ok, err = pcall(GenerateLuaTypes)
        if ok then
            log("Lua binding dump requested. Check Mods\\shared\\types after it completes.")
        else
            log("Lua binding dump failed: " .. tostring(err))
        end
    end)
end

consumeBindingDumpRequest()
log("DonationMod loaded! Run DonationDumpBindings from the server console to generate Lua types.")
